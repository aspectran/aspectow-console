# Polling configuration used only when WebSocket is not supported
pollingConfig: {
    # The interval in milliseconds at which the client polls the server for new messages
    pollingInterval: 3000
    # The duration in milliseconds after which an inactive polling session expires
    sessionTimeout: 30000
    # The initial capacity of the shared message buffer
    initialBufferSize: 9999
}
counterPersistInterval: 5
instance: {
    id: root
    title: Root
    event: {
        id: activity
        target: root
        parameters: {
            +: /**
        }
    }
    event: {
        id: session
        target: tow.server/root
    }
    metric: {
        id: heap
        title: Heap
        description: Shows JVM Heap memory usage status
        reader: com.aspectran.aspectow.appmon.engine.exporter.metric.jvm.HeapMemoryUsageReader
        sampleInterval: 500
        heading: true
    }
    metric: {
        id: undertow-tp
        title: Undertow TP
        description: Metrics of Undertow thread pool resources
        reader: com.aspectran.aspectow.appmon.engine.exporter.metric.undertow.NioWorkerMetricsReader
        target: tow.server
        sampleInterval: 500
        heading: true
    }
    log: {
        id: app
        file: /logs/root.log
        sampleInterval: 300
        lastLines: 1000
    }
    log: {
        id: access
        file: /logs/root-access.log
        sampleInterval: 300
        lastLines: 1000
    }
}
instance: {
    id: console
    title: Console
    event: {
        id: activity
        target: console
        parameters: {
            +: /**
            -: /backend/polling/**
        }
    }
    event: {
        id: session
        target: tow.server/console
    }
    log: {
        id: app
        file: /logs/console.log
        sampleInterval: 300
        lastLines: 1000
    }
    log: {
        id: access
        file: /logs/console-access.log
        sampleInterval: 300
        lastLines: 1000
    }
}
instance: {
    id: jpetstore
    title: JPetStore
    log: {
        id: app
        file: /logs/jpetstore.log
        sampleInterval: 300
        lastLines: 1000
    }
    log: {
        id: access
        file: /logs/jpetstore-access.log
        sampleInterval: 300
        lastLines: 1000
    }
}
instance: {
    id: demo
    title: Demo
    log: {
        id: app
        file: /logs/demo.log
        sampleInterval: 300
        lastLines: 1000
    }
    log: {
        id: access
        file: /logs/demo-access.log
        sampleInterval: 300
        lastLines: 1000
    }
}
